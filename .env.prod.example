# Production env file template.
#
# On `web01` this lives at /srv/3d-print-sales/env/web01.env (NOT in the repo).
# DO NOT COMMIT a populated copy. Real secrets stay on the host.

# ---- App ----
ENVIRONMENT=prod
LOG_LEVEL=INFO

# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-a-real-secret

# Secret-at-rest encryption key (Fernet) for sensitive DB columns such as the
# QuickBooks OAuth tokens. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required before connecting QuickBooks; keep it stable — rotating it makes
# previously-stored tokens undecryptable (reconnect to recover). Placeholder
# values are rejected at startup. See docs/secrets-at-rest.md.
SECRET_ENCRYPTION_KEY=replace-with-a-real-fernet-key

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://voxel:replace-me@db:5432/voxel_ledger
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

POSTGRES_USER=voxel
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=voxel_ledger

# ---- Host paths ----
# Where postgres stores its data on the host. Defaults to the canonical web01
# path; override only if you are running this stack somewhere else.
PG_DATA_DIR=/srv/3d-print-sales/data/pg

# ---- nginx ----
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- Migration escape hatch ----
# Set to 1 for code-only emergency redeploys when there is NO schema delta.
# See agents.md and print-sales-v2/11_operations_deployment.md.
SKIP_MIGRATIONS=0
