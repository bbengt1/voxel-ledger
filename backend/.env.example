# Copy to backend/.env and replace placeholder values with real secrets.
# The Settings validator will REFUSE to start the app while these sentinels
# remain — that is intentional. If `uvicorn app.main:app` rejects your env,
# look for `change-me` or empty strings below.

ENVIRONMENT=dev
LOG_LEVEL=INFO

# SQLAlchemy URL. Use the asyncpg driver in production.
DATABASE_URL=postgresql+asyncpg://voxel:change-me@localhost:5432/voxel_ledger
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_ECHO=false

# JWT signing key. Generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`.
JWT_SECRET_KEY=change-me
