# Voxel Ledger — web02 production env template.
#
# This file is repo-tracked. The POPULATED copy lives ONLY on the host at:
#   /srv/voxel-ledger/env/web02.env  (root:root, 0600)
#
# Bootstrap procedure (do NOT commit the populated copy):
#   1. Copy this file to /srv/voxel-ledger/env/web02.env on web02.
#   2. Replace every value tagged with `# CHANGE-ME` below.
#   3. Generate fresh JWT_SECRET_KEY and POSTGRES_PASSWORD with:
#        python3 -c "import secrets; print(secrets.token_urlsafe(48))"
#   4. chmod 600 /srv/voxel-ledger/env/web02.env && chown root:root ...
#
# Reference: docs/web02_bootstrap.md, docs/web02_runbook.md

# ---- App ----
ENVIRONMENT=prod
LOG_LEVEL=INFO

# JWT signing key. Backend Settings validator REJECTS sentinel values.
JWT_SECRET_KEY=CHANGE-ME-generate-with-secrets.token_urlsafe-48
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_PER_MINUTE=10

# ---- Database ----
# `db` is the in-network compose service hostname.
DATABASE_URL=postgresql+asyncpg://voxel:CHANGE-ME-db-password@db:5432/voxel_ledger
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

POSTGRES_USER=voxel
POSTGRES_PASSWORD=CHANGE-ME-db-password
POSTGRES_DB=voxel_ledger

# ---- Host paths (web02) ----
# Postgres data bind-mount on the host. Keep this aligned with the bootstrap
# script and docs/web02_bootstrap.md.
PG_DATA_DIR=/srv/voxel-ledger/data/pg

# ---- nginx ----
# Cloudflare Tunnel terminates TLS upstream; the container only needs HTTP.
NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443

# ---- Initial owner (consumed once by scripts/seed_owner.py if user table empty) ----
OWNER_EMAIL=CHANGE-ME@example.com
OWNER_PASSWORD=CHANGE-ME-strong-temporary-password

# ---- Migration escape hatch ----
# Set to 1 ONLY for code-only emergency redeploys with NO schema delta.
# See docs/web02_runbook.md.
SKIP_MIGRATIONS=0
