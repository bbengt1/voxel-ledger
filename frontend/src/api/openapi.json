        "tags": [
          "admin",
          "admin-audit-log"
        ]
      }
    },
    "/api/v1/admin/events/verify-chain": {
      "get": {
        "description": "Walk the event log in ``position`` order and recompute every hash.\n\nWindow-bounded: ``to_position - from_position`` may not exceed 1M.\nReturns ``ok=true`` for a clean chain, otherwise ``ok=false`` with\nthe position where the chain first breaks.",
        "operationId": "verify_chain_api_v1_admin_events_verify_chain_get",
        "parameters": [
          {
            "in": "query",
            "name": "from_position",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "From Position",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "to_position",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "To Position"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyChainResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Verify Chain",
        "tags": [
          "admin",
          "admin-events"
        ]
      }
    },
    "/api/v1/admin/reference-sequences": {
      "get": {
        "description": "Return every ``(prefix, year, last_value)`` row, sorted by\n``(prefix, year)``.",
        "operationId": "list_reference_sequences_api_v1_admin_reference_sequences_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ReferenceSequenceRow"
