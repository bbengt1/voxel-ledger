{
  "components": {
    "schemas": {
      "BulkSettingUpdateRequest": {
        "description": "POST body for a batch update.\n\nThe request is all-or-nothing: if any value fails validation, no\nwrites happen.",
        "properties": {
          "updates": {
            "additionalProperties": true,
            "title": "Updates",
            "type": "object"
          }
        },
        "required": [
          "updates"
        ],
        "title": "BulkSettingUpdateRequest",
        "type": "object"
      },
      "BulkSettingUpdateResponse": {
        "description": "Response for a successful batch update.\n\n``updated`` mirrors the request keys with their validated (typed)\nvalues as returned by the service.",
        "properties": {
          "updated": {
            "additionalProperties": true,
            "title": "Updated",
            "type": "object"
          }
        },
        "required": [
          "updated"
        ],
        "title": "BulkSettingUpdateResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "format": "email",
            "title": "Email",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "LogoutRequest": {
        "properties": {
          "refresh_token": {
            "title": "Refresh Token",
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "title": "LogoutRequest",
        "type": "object"
      },
      "MeResponse": {
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          },
          "full_name": {
            "title": "Full Name",
            "type": "string"
          },
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "is_active": {
            "title": "Is Active",
            "type": "boolean"
          },
          "role": {
            "$ref": "#/components/schemas/Role"
          }
        },
        "required": [
          "id",
          "email",
          "full_name",
          "role",
          "is_active"
        ],
        "title": "MeResponse",
        "type": "object"
      },
      "ReferenceSequenceRow": {
        "description": "A single ``reference_sequence`` row, surfaced via the admin API.",
        "properties": {
          "last_value": {
            "title": "Last Value",
            "type": "integer"
          },
          "prefix": {
            "title": "Prefix",
            "type": "string"
          },
          "year": {
            "title": "Year",
            "type": "integer"
          }
        },
        "required": [
          "prefix",
          "year",
          "last_value"
        ],
        "title": "ReferenceSequenceRow",
        "type": "object"
      },
      "RefreshRequest": {
        "properties": {
          "refresh_token": {
            "title": "Refresh Token",
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "title": "RefreshRequest",
        "type": "object"
      },
      "Role": {
        "description": "RBAC roles. Deny-by-default; presence in a `require_role` allowlist\nis the only thing that grants access.",
        "enum": [
          "owner",
          "bookkeeper",
          "production",
          "sales",
          "viewer"
        ],
        "title": "Role",
        "type": "string"
      },
      "SettingResponse": {
        "description": "One setting, merged with its schema default and provenance.",
        "properties": {
          "default": {
            "title": "Default"
          },
          "key": {
            "title": "Key",
            "type": "string"
          },
          "schema_type": {
            "description": "Friendly Python type name for the value (e.g. 'Decimal', 'str', 'dict'). Used by the frontend to pick an editor.",
            "title": "Schema Type",
            "type": "string"
          },
          "updated_at": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "When the row was last written. None if no row exists yet.",
            "title": "Updated At"
          },
          "updated_by_user_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "User who last wrote the row. None if from default.",
            "title": "Updated By User Id"
          },
          "value": {
            "title": "Value"
          }
        },
        "required": [
          "key",
          "value",
          "default",
          "schema_type"
        ],
        "title": "SettingResponse",
        "type": "object"
      },
      "SettingUpdateRequest": {
        "description": "PUT body for a single setting.",
        "properties": {
          "value": {
            "title": "Value"
          }
        },
        "required": [
          "value"
        ],
        "title": "SettingUpdateRequest",
        "type": "object"
      },
      "TokenPair": {
        "properties": {
          "access_token": {
            "title": "Access Token",
            "type": "string"
          },
          "expires_in": {
            "title": "Expires In",
            "type": "integer"
          },
          "refresh_token": {
            "title": "Refresh Token",
            "type": "string"
          },
          "token_type": {
            "default": "bearer",
            "title": "Token Type",
            "type": "string"
          }
        },
        "required": [
          "access_token",
          "refresh_token",
          "expires_in"
        ],
        "title": "TokenPair",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VerifyChainResponse": {
        "description": "Result of ``GET /admin/events/verify-chain``.\n\n``ok=True`` means every event's recomputed hash matches what we stored\nand every ``prev_event_hash`` matches the previous row's\n``event_hash``. ``broken_at_position`` is the first position where\nthe chain fails.",
        "properties": {
          "broken_at_position": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "First position where verification failed (None if ok=True).",
            "title": "Broken At Position"
          },
          "events_checked": {
            "default": 0,
            "title": "Events Checked",
            "type": "integer"
          },
          "last_position": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "description": "Last position the verifier successfully validated.",
            "title": "Last Position"
          },
          "ok": {
            "title": "Ok",
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ],
        "title": "VerifyChainResponse",
        "type": "object"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "voxel-ledger-backend",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/admin/events/verify-chain": {
      "get": {
        "description": "Walk the event log in ``position`` order and recompute every hash.\n\nWindow-bounded: ``to_position - from_position`` may not exceed 1M.\nReturns ``ok=true`` for a clean chain, otherwise ``ok=false`` with\nthe position where the chain first breaks.",
        "operationId": "verify_chain_api_v1_admin_events_verify_chain_get",
        "parameters": [
          {
            "in": "query",
            "name": "from_position",
            "required": false,
            "schema": {
              "default": 0,
              "minimum": 0,
              "title": "From Position",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "to_position",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "minimum": 1,
                  "type": "integer"
                },
                {
                  "type": "null"
                }
              ],
              "title": "To Position"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerifyChainResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "Verify Chain",
        "tags": [
          "admin",
          "admin-events"
        ]
      }
    },
    "/api/v1/admin/reference-sequences": {
      "get": {
        "description": "Return every ``(prefix, year, last_value)`` row, sorted by\n``(prefix, year)``.",
        "operationId": "list_reference_sequences_api_v1_admin_reference_sequences_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ReferenceSequenceRow"
                  },
                  "title": "Response List Reference Sequences Api V1 Admin Reference Sequences Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List Reference Sequences",
        "tags": [
          "admin",
          "admin-reference-sequences"
        ]
      }
    },
