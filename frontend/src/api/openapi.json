                  "title": "Response List Reference Sequences Api V1 Admin Reference Sequences Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "summary": "List Reference Sequences",
        "tags": [
          "admin",
          "admin-reference-sequences"
        ]
      }
    },
