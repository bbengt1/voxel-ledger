# Local development env file.
# Copy to .env.dev (gitignored) before running `scripts/compose.sh up`.

# ---- App ----
ENVIRONMENT=dev
LOG_LEVEL=INFO

# JWT signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-please-regenerate-for-anything-real-c9f1b8e7

# ---- Database ----
# Compose sets DATABASE_URL to point at the `db` service if you don't.
DATABASE_URL=postgresql+asyncpg://voxel:voxel@db:5432/voxel_ledger
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_ECHO=false

# Postgres container init values. Match the user/password in DATABASE_URL.
POSTGRES_USER=voxel
POSTGRES_PASSWORD=voxel
POSTGRES_DB=voxel_ledger

# ---- Host port overrides ----
POSTGRES_HOST_PORT=5432
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173

# ---- Frontend ----
# Origin only — every call site provides the full path including the
# /api/v1 prefix to match the generated OpenAPI types in src/api/types.ts.
VITE_API_BASE_URL=http://localhost:8000

# ---- CORS ----
# Comma-separated list of origins allowed to call the backend. The Vite dev
# server defaults to http://localhost:5173. Empty disables CORS entirely.
CORS_ORIGINS=http://localhost:5173

# ---- QuickBooks Online OAuth (epic #312) ----
# Sandbox keys from your Intuit developer app. Leave blank to keep QBO off.
# The redirect URI must match the app's registered redirect EXACTLY.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:8000/api/v1/admin/quickbooks/callback
QBO_ENVIRONMENT=sandbox
