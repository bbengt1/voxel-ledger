      "typeVersion": 1,
      "position": [240, 320]
    },
    {
      "parameters": {
        "command": "cd /srv/3d-print-sales/repo && git fetch origin && git checkout main && git pull --ff-only origin main && git rev-parse --short HEAD"
      },
      "id": "5b2d0b7c-1a2c-4f1d-9b2e-000000000002",
      "name": "1. Pull latest main",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [480, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web01 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "command": "cd /srv/3d-print-sales/repo && scripts/web01-compose.sh run --rm backend alembic upgrade head"
      },
      "id": "5b2d0b7c-1a2c-4f1d-9b2e-000000000003",
      "name": "2. Run migrations (alembic upgrade head)",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [720, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web01 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "command": "cd /srv/3d-print-sales/repo && scripts/web01-compose.sh up -d --build && scripts/web01-compose.sh ps"
      },
      "id": "5b2d0b7c-1a2c-4f1d-9b2e-000000000004",
      "name": "3. Rebuild + rotate containers",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [960, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web01 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "url": "http://web01.bengtson.local/health",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": false
            }
          }
        }
      },
      "id": "5b2d0b7c-1a2c-4f1d-9b2e-000000000005",
      "name": "4. Verify /health (expect 200)",
