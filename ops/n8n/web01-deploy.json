        "method": "HEAD",
        "url": "http://web01.bengtson.local/",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": false
            }
          },
          "redirect": {
            "redirect": {
              "followRedirects": false
            }
          }
        }
      },
      "id": "5b2d0b7c-1a2c-4f1d-9b2e-000000000006",
      "name": "5. Verify / (frontend served)",
