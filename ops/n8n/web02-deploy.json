{
  "name": "web02-deploy",
  "nodes": [
    {
      "parameters": {},
      "id": "a1b2c3d4-0000-4000-8000-000000000001",
      "name": "Deploy web02 (manual trigger)",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [240, 320]
    },
    {
      "parameters": {
        "command": "cd /srv/voxel-ledger/repo && git fetch origin && git checkout main && git pull --ff-only origin main && git rev-parse --short HEAD"
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000002",
      "name": "1. Pull latest main",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [480, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web02 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "command": "cd /srv/voxel-ledger/repo && scripts/web02-compose.sh run --rm backend alembic upgrade head"
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000003",
      "name": "2. Run migrations (alembic upgrade head)",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [720, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web02 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "command": "cd /srv/voxel-ledger/repo && scripts/web02-compose.sh up -d --build && scripts/web02-compose.sh ps"
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000004",
      "name": "3. Rebuild + rotate containers",
      "type": "n8n-nodes-base.ssh",
      "typeVersion": 1,
      "position": [960, 320],
      "credentials": {
        "sshPassword": {
          "id": "REPLACE_WITH_SSH_CREDENTIAL_ID",
          "name": "web02 ssh (root)"
        }
      },
      "continueOnFail": false
    },
    {
      "parameters": {
        "url": "http://web02.internal/health",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": false
            }
          }
        }
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000005",
      "name": "4. Verify /health (expect 200)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1200, 320],
      "continueOnFail": false
    },
    {
      "parameters": {
        "method": "HEAD",
        "url": "http://web02.internal/",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true,
              "neverError": false
            }
          },
          "redirect": {
            "redirect": {
              "followRedirects": false
            }
          }
        }
      },
      "id": "a1b2c3d4-0000-4000-8000-000000000006",
      "name": "5. Verify / (frontend served)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1440, 320],
      "continueOnFail": false
    }
  ],
  "connections": {
    "Deploy web02 (manual trigger)": {
      "main": [
        [
          {
            "node": "1. Pull latest main",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "1. Pull latest main": {
      "main": [
        [
          {
            "node": "2. Run migrations (alembic upgrade head)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "2. Run migrations (alembic upgrade head)": {
      "main": [
        [
          {
            "node": "3. Rebuild + rotate containers",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "3. Rebuild + rotate containers": {
      "main": [
        [
          {
            "node": "4. Verify /health (expect 200)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "4. Verify /health (expect 200)": {
      "main": [
        [
          {
            "node": "5. Verify / (frontend served)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveExecutionProgress": true,
    "saveDataSuccessExecution": "all",
    "saveDataErrorExecution": "all"
  },
  "tags": [
    {
      "name": "deploy"
    },
    {
      "name": "web02"
    }
  ],
  "meta": {
    "description": "Canonical web02 deploy workflow. Pull -> migrate -> rebuild -> verify. Each step is a separate node so n8n's per-node logs make failures obvious. SSH credential 'web02 ssh (root)' must be configured on import (the ID in this export is a placeholder). A GitHub-webhook trigger will be added once n8n.internal has inbound ingress via Cloudflare Tunnel; until then the workflow is manual-execute only."
  }
}
